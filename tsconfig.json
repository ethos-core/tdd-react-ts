{
  "compilerOptions": {
    "types": ["vitest/globals"],
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  },
  "include": ["src", "vitest.config.ts"]
}
